{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "code-review-graph update --skip-flows",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "code-review-graph status",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}